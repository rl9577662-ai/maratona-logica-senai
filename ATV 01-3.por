programa {
  funcao inicio() {
    real valor, hora, resultado
    escreva ("Qual o valor da hora trabalhada: ")
    leia (valor)
    escreva("Quantas horas foram trabalhadas: ")
    leia (hora)
    resultado=valor*hora
    escreva ("Esse eo valor da sua hora trabalhada: ", resultado)
      }
    }
