programa {
  funcao inicio() {
    real a, b
    escreva ("Qual a produção do setor A: ")
    leia (a)
    escreva ("Qual a produção do setor B: ")
    leia (b)
    se (a>b)
    escreva ("A produção do setor A foi maior que a do setor B")
    se (a<b)
    escreva ("A produção do setor B foi maior que a do setor A")
  }
}
