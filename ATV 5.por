programa {
  funcao inicio() {
    real num1, num2, num3, resultado
escreva("digite o valor da primeira maquina: ")
leia (num1)

escreva ("digite o valor da segunda maquina: ")
leia (num2)

escreva("digite o valor da terceira maquina: ")
leia (num3)

resultado=(num1+num2+num3)/3

escreva ("A media e: ", resultado)

  }
}
